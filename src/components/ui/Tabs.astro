---
const { items = ['Прибирання', 'Хімчистка'], activeIndex = 1 } = Astro.props;
---

<div class="tabs-container">
  {items.map((item, index) => (
    <button class={`tab ${index === activeIndex ? 'active' : ''}`}>
      {item}
    </button>
  ))}
</div>

<style>
  .tabs-container {
    display: flex;
    gap: 17px;
    border-bottom: 2px solid transparent;
  }

  .tab {
    background: none;
    border: none;
    padding: 8px 0 14px 0;
    font-family: 'Unbounded', sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--main-text-color);
    cursor: pointer;
    position: relative;
    transition: color 0.3s ease;
  }

  .tab:hover {
    color: var(--primary-color);
  }

  .tab.active {
    color: var(--primary-color);
  }

  .tab.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background-color: var(--primary-color);
  }
</style>