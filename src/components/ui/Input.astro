---
const { placeholder = "(000) 000-00-00", errorMessage, name = "phone" } = Astro.props;
---

<div class="input-wrapper">
  <div class="input-with-prefix">
    <span class="prefix">+38</span>
    <div class="input-container">
      <input type="tel" name={name} placeholder={placeholder} maxlength="15" class="phone-input" />
      {errorMessage && (
        <svg class="error-icon" aria-hidden="true">
          <use href="/sprite.svg#viber" />
        </svg>
      )}
    </div>
  </div>

  {errorMessage && <span class="error-message">{errorMessage}</span>}
</div>

<style>
  .input-wrapper {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
    max-width: 320px;
  }

  .input-with-prefix {
    display: flex;
    align-items: center;
    height: 44px;
  }

  .prefix {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    height: 100%;
    font-family: 'Google Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--main-text-color);
    background-color: var(--grey-100-white-color);
    border: 1px solid var(--grey-700-stroke-color);
    border-right: none;
  }

  .input-container {
    display: flex;
    flex: 1;
    align-items: center;
    height: 100%;
    background-color: var(--grey-100-white-color);
    border: 1px solid var(--grey-700-stroke-color);
    transition: border-color 0.3s ease;
  }

  .input-container:focus-within {
    border-color: var(--primary-color);
  }

  input {
    flex: 1; 
    height: 100%;
    border: none;
    outline: none; 
    background: transparent;
    padding: 0 16px;
    font-family: 'Google Sans', sans-serif; 
    font-size: 14px;
    color: var(--main-text-color);
  }

  input::placeholder {
    color: var(--secondary-text-color);
  }

  .error-message {
    font-family: 'Google Sans', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: var(--error-color);
  }

  .error-icon {
    width: 20px;
    height: 20px;
    margin-right: 16px;
    color: var(--error-color);
    flex-shrink: 0;
  }
</style>

<script>
  document.querySelectorAll('.phone-input').forEach((input) => {
    input.addEventListener('input', function (e) {
      let value = this.value.replace(/\D/g, '');
      let formattedValue = '';

      if (value.length > 0) formattedValue += '(' + value.substring(0, 3);
      if (value.length >= 4) formattedValue += ') ' + value.substring(3, 6);
      if (value.length >= 7) formattedValue += '-' + value.substring(6, 8);
      if (value.length >= 9) formattedValue += '-' + value.substring(8, 10);

      this.value = formattedValue;
    });
  });
</script>