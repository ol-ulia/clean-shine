---
const { text = "Підказка за замовчуванням", iconId = "info" } = Astro.props;
---

<div class="tooltip-wrapper">
  <span class="info-icon">
    <svg class="icon"><use href={`/sprite.svg#${iconId}`}></use></svg>
  </span>

  <div class="tooltip-content">
    {text}
  </div>
</div>

<style>
  .tooltip-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: help;
  }

  .info-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
  }

  .icon {
    width: 100%;
    height: 100%;
    color: var(--secondary-text-color);
  }

  .tooltip-content {
    position: absolute;
    top: 130%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    width: max-content;
    max-width: 260px;
    padding: 12px;
    background-color: var(--secondary-text-color);
    color: var(--100-white-color);
    font-family: 'Google Sans', sans-serif;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.4;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .tooltip-content::before {
    content: '';
    position: absolute;
    bottom: 95%;
    left: 50%;
    transform: translateX(-50%);
    border-width: 10px;
    border-style: solid;
    border-color: transparent transparent var(--secondary-text-color) transparent;
  }

  .tooltip-wrapper:hover .tooltip-content {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(8px);
  }

  @media (max-width: 400px) {
    .tooltip-content {
      max-width: 200px;
    }
  }
</style>