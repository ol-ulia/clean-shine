---
---

<header class="header">
  <div class="header-container">

    <a href="/" class="logo-link" aria-label="Clean Shine — головна">
      <svg class="logo-large" aria-hidden="true"><use href="/sprite.svg#logo-large"></use></svg>
      <svg class="logo-mobile" aria-hidden="true"><use href="/sprite.svg#logo-mobile"></use></svg>
    </a>

    <div class="contacts-wrapper">

      <div class="contact-row">
        <div class="social-group">
          <a href="viber://..." class="social-icon social-icon--viber" aria-label="Viber">
            <svg aria-hidden="true"><use href="/sprite.svg#up-arrow"></use></svg>
          </a>
          <a href="https://t.me/..." class="social-icon social-icon--telegram" aria-label="Telegram">
            <svg aria-hidden="true"><use href="/sprite.svg#stars-filled"></use></svg>
          </a>
        </div>
        <a href="tel:+380662069994" class="phone-link">+380 66 206 99 94</a>
      </div>

      <div class="contact-row">
        <a href="https://instagram.com/clean.shine.ua" class="social-icon social-icon--instagram" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <defs>
              <radialGradient id="ig-grad" cx="30%" cy="110%" r="140%">
                <stop offset="0%" stop-color="#FFD521"/>
                <stop offset="20%" stop-color="#FF7A00"/>
                <stop offset="45%" stop-color="#FF0069"/>
                <stop offset="70%" stop-color="#D300C5"/>
                <stop offset="100%" stop-color="#7638FA"/>
              </radialGradient>
            </defs>
            <rect width="24" height="24" rx="12" fill="url(#ig-grad)"/>
