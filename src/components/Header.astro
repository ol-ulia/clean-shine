        </a>
        <a href="https://instagram.com/clean.shine.ua" class="insta-link" target="_blank" rel="noopener">
          Clean.shine.ua
        </a>
      </div>

    </div>
  </div>
</header>

<style>
  .header {
    background-color: var(--100-white-color);
    padding: 19px 20px;
  }

  .header-container {
    max-width: 1170px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
  }

  .logo-large {
    display: block;
    width: 244px;
    height: 54px;
  }

  .logo-mobile {
    display: none;
    width: 110px;
    height: 48px;
  }

  .contacts-wrapper {
    display: flex;
    align-items: center;
    gap: 56px;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .social-group {
    display: flex;
    gap: 12px;
  }

  .social-icon--viber {
    color: #7360F2;
  }

  .social-icon--telegram {
    color: #29A9EB;
  }

  .social-icon--instagram svg {
    width: 24px;
    height: 24px;
  }

  .social-icon svg {
    width: 24px;
    height: 24px;
    display: block;
  }

  .social-icon:hover svg {
    transform: scale(1.1);
    transition: transform 0.2s ease;
  }

  .phone-link,
  .insta-link {
    font-family: 'Google Sans', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--main-text-color);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .phone-link:hover,
  .insta-link:hover {
    color: var(--primary-color);
  }

  @media (max-width: 768px) {
    .header {
      padding: 16px;
    }

    .logo-large {
      display: none;
    }

    .logo-mobile {
      display: block;
    }

    .contacts-wrapper {
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
    }

    .contact-row {
      gap: 8px;
    }

    .phone-link,
    .insta-link {
      font-size: 14px;
    }

    .social-icon svg {
      width: 20px;
      height: 20px;
    }
  }
</style>