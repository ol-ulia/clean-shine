<header class="header">
  <div class="container header-container">
    <a href="/" class="logo-link">
      <svg class="logo-large"><use href="/sprite.svg#logo-large"></use></svg>
      <svg class="logo-mobile"><use href="/sprite.svg#logo-mobile"></use></svg>
    </a>

    <div class="contacts-wrapper">
      <div class="contact-row">
        <div class="social-group">
          <a href="#" class="social-icon" aria-label="Viber"><svg class="icon"><use href="/sprite.svg#viber"></use></svg></a>
          <a href="#" class="social-icon" aria-label="Telegram"><svg class="icon"><use href="/sprite.svg#telegram"></use></svg></a>
        </div>
        <a href="tel:+380662069994" class="phone-link">+380 66 206 99 94</a>
      </div>

      <div class="contact-row">
        <a href="https://instagram.com/clean.shine.ua" class="social-icon" target="_blank" aria-label="Instagram">
          <svg class="icon"><use href="/sprite.svg#instagram"></use></svg>
        </a>
        <a href="https://instagram.com/clean.shine.ua" class="insta-link" target="_blank">Clean.shine.ua</a>
      </div>
    </div>
  </div>
</header>

<style>
  /* Базовий контейнер (робимо його спільним для всіх секцій сайту) */
  .container {
    max-width: 1600px; 
    max-height: 92px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .header {
    background-color: var(--100-white-color); /* Білий фон з макета */
    padding: 19px 215px 19px 215px; /* Відступи зверху і знизу */
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 50px;
  }

  /* Налаштування логотипів: за замовчуванням показуємо десктопний */
  .logo-mobile {
    display: none;
    width: 110px;
    height: 48px;
  }

  .logo-large {
    width: 244px;
    height: 54px;
  }

  .contacts-wrapper {
    display: flex;
    gap: 56px; /* Відстань між двома блоками контактів на ПК */
    align-items: center;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .social-group {
    display: flex;
    gap: 12px;
  }

  .social-icon .icon {
    width: 24px;
    height: 24px;
    transition: transform 0.3s ease;
  }

  .social-icon:hover .icon {
    transform: scale(1.1); /* Легке збільшення при наведенні */
  }

  /* Типографіка посилань */
  .phone-link, .insta-link {
    font-family: 'Google Sans', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--main-text-color);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .phone-link:hover, .insta-link:hover {
    color: var(--primary-color);
  }

  /* --- АДАПТИВНІСТЬ ДЛЯ МОБІЛЬНИХ (Екрани менші за 768px) --- */
  @media (max-width: 768px) {
    .container {
    max-width: 393px; 
    max-height: 80px;
    margin: 0 auto;
    padding: 0px;

  }

  .header {
    background-color: var(--100-white-color); /* Білий фон з макета */
    padding: 16px 16px 16px 16px; /* Відступи зверху і знизу */
  }
    .header-container {
      /* Додаємо відстань між логотипом і контактами, якщо екран дуже вузький */
      gap: 16px; 
    }

    /* Ховаємо десктопний логотип, показуємо мобільний */
    .logo-large {
      display: none;
    }
    
    .logo-mobile {
      display: block;
    }

    /* Контакти ставимо в колонку (один під одним) */
    .contacts-wrapper {
      flex-direction: column;
      align-items: flex-end; /* Вирівнюємо по правому краю */
      gap: 8px;
    }

    .contact-row {
    gap: 4px;
  }

  .social-group {
    gap: 8px;
  }

  .social-icon .icon {
    width: 20px;
    height: 20px;
  }

    /* Зменшуємо шрифти для мобілки */
    .phone-link, .insta-link {
      font-size: 14px;
    }
  }
</style>