<style is:global>
  :root {
    --main-text-color: #1C2B36;
    --secondary-text-color: #808D99;
    --primary-color: #59ACF3;
    --accent-main-color: #FFD659;
    --accent-hover-color: #FFC410;
    --grey-700-stroke-color: #CCD5DE;
    --grey-500-bg-color: #F1F6FA;
    --grey-100-white-color: #F1F6FA;
    --error-color: #EE2020;
    --100-white-color: #FFFFFF;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    padding: 0;
    font-family: 'Unbounded', sans-serif;
    color: var(--main-text-color);
    background-color: var(--grey-500-bg-color);
  }
</style>
